# ============================================================
# 合同比对专业版 - 环境变量模板
# 复制为 .env 并根据实际环境修改
# ============================================================

# ---- OCR 配置 ----
# OCR 文本识别置信度阈值（0.0 - 1.0），低于此值的文本标记为需复核
OCR_CONFIDENCE_THRESHOLD=0.5

# ---- LLM 配置 ----
# 是否启用 LLM 语义分析（需要先启动 Ollama 服务）
LLM_ENABLED=false
# Ollama 模型名称
LLM_MODEL=qwen3.5-0.8b
# Ollama 服务地址
LLM_BASE_URL=http://localhost:11434

# ---- 输出目录 ----
# 报告输出目录（容器内路径，通常无需修改）
OUTPUT_DIR=/app/output
# 配置 / 模板文件目录
PROFILE_DIR=/app/profiles

# ---- 日志级别 ----
# DEBUG / INFO / WARNING / ERROR
LOG_LEVEL=INFO

# ---- API 服务 ----
# FastAPI 监听地址和端口
API_HOST=0.0.0.0
API_PORT=8080

# ---- Streamlit 服务 ----
# Streamlit 端口
STREAMLIT_PORT=8501

# ---- 加密配置 ----
# Fernet 对称加密密钥（用于加密存储 API Key 等敏感数据）
# 生成方法: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 注意：密钥丢失将导致已加密数据无法恢复，请务必妥善备份
# ENCRYPTION_KEY=

# ---- Ollama 服务 ----
# Ollama 端口（仅 docker-compose 使用）
OLLAMA_PORT=11434